#!/bin/bash
set -euo pipefail

BUNDLE_GCS_URI="${BUILDKITE_PLUGIN_GIT_BUNDLE_GCS_URI}"
BUNDLE_PATH="/tmp/buildkite-git-bundle.bundle"
REF_REPO="/workspace/.git-bundle-ref.git"

add_ref_flags() {
  export BUILDKITE_GIT_CLONE_FLAGS="${BUILDKITE_GIT_CLONE_FLAGS:-} --reference-if-able ${REF_REPO} --dissociate"
}

if [ -d "${REF_REPO}" ]; then
  add_ref_flags
  echo "git-bundle: reference repo already present, reusing"
  exit 0
fi

if ! gcloud storage cp "${BUNDLE_GCS_URI}" "${BUNDLE_PATH}"; then
  echo "git-bundle: bundle unavailable, normal clone from origin"
  exit 0
fi

if ! git bundle verify "${BUNDLE_PATH}" >/dev/null 2>&1; then
  echo "git-bundle: bundle invalid, normal clone from origin"
  rm -f "${BUNDLE_PATH}"
  exit 0
fi

echo "git-bundle: building reference repo from bundle"
git clone --bare "${BUNDLE_PATH}" "${REF_REPO}"
rm -f "${BUNDLE_PATH}"
add_ref_flags
echo "git-bundle: reference ready (${REF_REPO}); BUILDKITE_GIT_CLONE_FLAGS=${BUILDKITE_GIT_CLONE_FLAGS}"

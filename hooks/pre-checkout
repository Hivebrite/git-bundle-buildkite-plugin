#!/bin/bash
set -euo pipefail

BUNDLE_GCS_URI="${BUILDKITE_PLUGIN_GIT_BUNDLE_GCS_URI}"
BUNDLE_PATH="/tmp/buildkite-git-bundle.bundle"

if ! gsutil -m -q cp "${BUNDLE_GCS_URI}" "${BUNDLE_PATH}" 2>/dev/null; then
  echo "git-bundle: bundle unavailable, falling back to full clone"
  exit 0
fi

export BUILDKITE_GIT_CLONE_FLAGS="${BUILDKITE_GIT_CLONE_FLAGS:+${BUILDKITE_GIT_CLONE_FLAGS} }--bundle-uri=${BUNDLE_PATH}"

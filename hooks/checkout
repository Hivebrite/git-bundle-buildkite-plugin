#!/bin/bash
set -euo pipefail

CACHE_URI="${BUILDKITE_PLUGIN_GIT_BUNDLE_GCS_URI}"
TAR="/tmp/buildkite-git-cache.tar"
CO="${BUILDKITE_BUILD_CHECKOUT_PATH}"
REPO="${BUILDKITE_REPO}"
COMMIT="${BUILDKITE_COMMIT}"
CLONE_FLAGS="${BUILDKITE_GIT_CLONE_FLAGS:--v}"
FETCH_FLAGS="${BUILDKITE_GIT_FETCH_FLAGS:--v}"

# Report how many bytes the last git operation pulled over the network (GitHub).
report_github_transfer() {
  local label="$1" logf="$2"
  local line
  line=$(grep -aoE "Receiving objects: 100% \([0-9]+/[0-9]+\), [0-9.]+ [KMG]iB" "${logf}" | tail -1)
  if [ -z "${line}" ]; then
    line=$(grep -aoE "Total [0-9]+ \(delta [0-9]+\)" "${logf}" | tail -1)
  fi
  echo "git-bundle: ${label} GitHub transfer: ${line:-<none / already local>}"
}

normal_checkout() {
  if [ ! -d .git ]; then
    # shellcheck disable=SC2086
    git clone ${CLONE_FLAGS} -- "${REPO}" . 2>/tmp/gb_net
  fi
  git remote set-url origin "${REPO}"
  # shellcheck disable=SC2086
  git fetch ${FETCH_FLAGS} -- origin "${COMMIT}" 2>>/tmp/gb_net
  report_github_transfer "NORMAL CLONE (no cache)" /tmp/gb_net
  git checkout -f "${COMMIT}"
  git clean -ffxdq
}

mkdir -p "${CO}"
cd "${CO}"

if [ -d .git ]; then
  normal_checkout
  exit 0
fi

# Only seed plain depth-1 checkouts. Steps asking for deeper history or tags
# (release/deploy, monorepo-diff "Detect changes" via git-flags) need real
# history -> Buildkite's normal checkout.
case " ${CLONE_FLAGS} ${FETCH_FLAGS} " in
  *" --depth=1 "*) : ;;
  *) echo "git-bundle: non-shallow step, using normal checkout"; normal_checkout; exit 0 ;;
esac
case " ${CLONE_FLAGS} ${FETCH_FLAGS} " in
  *"--tags"*) echo "git-bundle: tags requested, using normal checkout"; normal_checkout; exit 0 ;;
esac

if ! gcloud storage cp "${CACHE_URI}" "${TAR}" 2>/tmp/gb_err; then
  echo "git-bundle: cache unavailable ($(tail -c 150 /tmp/gb_err)); normal checkout"
  normal_checkout
  exit 0
fi
echo "git-bundle: downloaded git cache from GCS (in-infra): $(du -h "${TAR}" | cut -f1)"

seed_ok=false
if tar -xf "${TAR}" -C "${CO}" 2>/tmp/gb_err && [ -d "${CO}/.git" ]; then
  git remote set-url origin "${REPO}" 2>>/tmp/gb_err || true
  # shellcheck disable=SC2086
  if git fetch ${FETCH_FLAGS} -- origin "${COMMIT}" 2>/tmp/gb_net \
     && git checkout -f "${COMMIT}" 2>>/tmp/gb_err; then
    git clean -ffxdq
    seed_ok=true
  fi
fi
rm -f "${TAR}"

if [ "${seed_ok}" = true ]; then
  report_github_transfer "SEEDED (delta only)" /tmp/gb_net
  echo "git-bundle: SEEDED checkout from GCS cache — GitHub served only the commit delta (.git=$(du -sh .git 2>/dev/null | cut -f1))"
  buildkite-agent annotate --context git-bundle --style success "seeded from GCS cache — GitHub delta: $(grep -aoE 'Receiving objects: 100% \([0-9]+/[0-9]+\), [0-9.]+ [KMG]iB' /tmp/gb_net | tail -1 || echo none)" 2>/dev/null || true
else
  echo "git-bundle: seed failed ($(tail -c 200 /tmp/gb_err)); falling back to normal checkout"
  cd /
  rm -rf "${CO:?}"
  mkdir -p "${CO}"
  cd "${CO}"
  normal_checkout
fi

#!/bin/bash
set -euo pipefail

GCS_URI="${BUILDKITE_PLUGIN_GIT_BUNDLE_GCS_URI}"
BUNDLE="/tmp/buildkite-git-bundle.bundle"
CO="${BUILDKITE_BUILD_CHECKOUT_PATH}"
REPO="${BUILDKITE_REPO}"
COMMIT="${BUILDKITE_COMMIT}"
CLONE_FLAGS="${BUILDKITE_GIT_CLONE_FLAGS:--v}"
FETCH_FLAGS="${BUILDKITE_GIT_FETCH_FLAGS:--v}"

note() { buildkite-agent annotate --context git-bundle --style info "$1" 2>/dev/null || true; }

normal_checkout() {
  if [ ! -d .git ]; then
    # shellcheck disable=SC2086
    git clone ${CLONE_FLAGS} -- "${REPO}" .
  fi
  git remote set-url origin "${REPO}"
  # shellcheck disable=SC2086
  git fetch ${FETCH_FLAGS} -- origin "${COMMIT}"
  git checkout -f "${COMMIT}"
  git clean -ffxdq
}

mkdir -p "${CO}"
cd "${CO}"

if [ -d .git ]; then
  normal_checkout
  exit 0
fi

# The bundle is a shallow (depth-1) snapshot of the default branch. Only seed
# steps that do a plain depth-1 checkout; steps that ask for deeper history or
# tags (release/deploy steps, monorepo-diff "Detect changes" via git-flags)
# need real history, so let Buildkite's normal checkout handle them.
case " ${CLONE_FLAGS} ${FETCH_FLAGS} " in
  *" --depth=1 "*) : ;;
  *) normal_checkout; exit 0 ;;
esac
case " ${CLONE_FLAGS} ${FETCH_FLAGS} " in
  *"--tags"*) normal_checkout; exit 0 ;;
esac

if ! gcloud storage cp "${GCS_URI}" "${BUNDLE}" 2>/tmp/gb_err; then
  note "bundle download failed, normal checkout: $(head -c 200 /tmp/gb_err)"
  normal_checkout
  exit 0
fi

seed_ok=false
if git clone --no-checkout "${BUNDLE}" . 2>/tmp/gb_err; then
  git remote set-url origin "${REPO}"
  # shellcheck disable=SC2086
  if git fetch ${FETCH_FLAGS} -- origin "${COMMIT}" 2>>/tmp/gb_err \
     && git checkout -f "${COMMIT}" 2>>/tmp/gb_err; then
    git clean -ffxdq
    seed_ok=true
  fi
fi
rm -f "${BUNDLE}"

if [ "${seed_ok}" = true ]; then
  note "seeded from bundle OK (.git=$(du -sh .git 2>/dev/null | cut -f1))"
else
  note "seed failed, normal checkout: $(tail -c 300 /tmp/gb_err)"
  rm -rf "${CO:?}/".git "${CO:?}"/* 2>/dev/null || true
  normal_checkout
fi
